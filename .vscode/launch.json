{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dependency Radar: Backend (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "${workspaceFolder}/src/Depmap.Service/bin/Debug/net8.0/DependencyRadar.Service.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Depmap.Service",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5001"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(http://\\S+)"
      }
    },
    {
      "name": "Dependency Radar: Web (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "web: dev",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/Depmap.Web/src",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Dependency Radar: Full Stack",
      "configurations": ["Dependency Radar: Backend (.NET)", "Dependency Radar: Web (Chrome)"],
      "stopAll": true
    }
  ]
}
