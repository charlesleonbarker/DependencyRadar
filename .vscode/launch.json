{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dependency Radar: Backend (.NET)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "${workspaceFolder}/src/DependencyRadar.Service/bin/Debug/net8.0/DependencyRadar.Service.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/DependencyRadar.Service",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5001"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(http://\\S+)"
      }
    },
    {
      "name": "Dependency Radar: Web (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "web: dev",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/DependencyRadar.Web/src",
      "sourceMaps": true
    },
    {
      "name": "Dependency Radar: Storybook (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "storybook: dev",
      "url": "http://localhost:6006",
      "webRoot": "${workspaceFolder}/src/DependencyRadar.Web/src",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Dependency Radar: Full Stack",
      "configurations": [
        "Dependency Radar: Backend (.NET)",
        "Dependency Radar: Web (Chrome)"
      ],
      "stopAll": true
    },
    {
      "name": "Dependency Radar: Full Stack + Storybook",
      "configurations": [
        "Dependency Radar: Backend (.NET)",
        "Dependency Radar: Web (Chrome)",
        "Dependency Radar: Storybook (Chrome)"
      ],
      "stopAll": true
    }
  ]
}
